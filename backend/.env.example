# Comma-separated list of origins allowed to call this API.
# In production, set to the deployed frontend URL(s), e.g.:
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Gemini API key for /api/narrative. If unset, the endpoint returns a
# deterministic template thesis built from the same payload (demo-safe).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Finnhub API key for /api/price (live stock quote). Free tier at
# finnhub.io/register. If unset, /api/price serves the seeded last close.
FINNHUB_API_KEY=

# SEC EDGAR requires a descriptive User-Agent with a real contact email or it
# 403s. Used by /api/edgar for the live filing pull.
SEC_USER_AGENT=Perigee-Hackathon-Demo your-email@example.com

# /api/trends pulls live from Google Trends (pytrends) by default. Set this to
# 1 to pin to the seeded weekly series (a controlled trend shape for a scripted
# demo, immune to pytrends rate-limits).
PERIGEE_TRENDS_CACHED=

# Turso (hosted libSQL) for data that persists across Vercel cold starts.
# Set BOTH to switch off local SQLite and use Turso; leave unset for local dev.
# Get these from the Turso dashboard: the database URL (libsql://... or the
# https:// form) and a database auth token. Set them in Vercel's env vars too.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
